#Dump PID from XDR Forensics Memory capture via Volatility
    
    
    
import sys
from pathlib import Path
from volatility3.cli import CommandLine

case_root = Path(r"{{ .XDRForensicsFilePath }}")
output_dir = Path(r"{{ .OutputDirectory }}")
pid_value = "{{ .PIDID }}"

if case_root.is_dir():
  matches = list(case_root.rglob("ram-image.raw"))
  if not matches:
    raise FileNotFoundError(f"No ram-image.raw found under {case_root}")
  dumppath = matches[0]
else:
  dumppath = case_root

output_dir.mkdir(parents=True, exist_ok=True)

print(f"[+] Using memory image: {dumppath}")
print(f"[+] Output directory: {output_dir}")
print(f"[+] PID: {pid_value}")

sys.argv = [
  "vol",
  "-q",
  "-f", str(dumppath),
  "-o", str(output_dir),
  "windows.memmap",
  "--pid", str(pid_value),
  "--dump",
  ]

CommandLine().run()
